PORT=3000
NODE_ENV=development
DATABASE_URL=./data/timeoff.db
HCM_BASE_URL=
HCM_API_KEY=
# Outbound HCM HTTP timeout (ms) when HCM_BASE_URL is set.
HCM_TIMEOUT_MS=15000

# Standalone mock server only (see npm run mock-hcm:serve).
MOCK_HCM_PORT=4010
MOCK_HCM_API_KEY=

# When set, protected routes require X-Api-Key: <API_KEY> (and GET /health, GET /balances,
# GET /time-off-requests when JWT is off, Bearer API_KEY is still accepted for API_KEY only mode).
# When JWT_ISSUER + JWT_SECRET or JWT_JWKS_URI are set, use X-Api-Key for this value and
# Authorization: Bearer <end-user JWT> for identity. Leave empty for local dev.
API_KEY=
# Optional previous key during rotation window (accepted with API_KEY).
API_KEY_PREVIOUS=

# Optional HTTPS (Nest TLS). Paths to PEM certificate and private key.
TLS_CERT_PATH=
TLS_KEY_PATH=

# Behind ingress/reverse proxy (recommended in production for TLS termination + real client IP).
TRUST_PROXY=true

# Browser hardening.
CORS_ENABLED=true
# Comma-separated allowlist. Use * only for non-production.
CORS_ORIGIN=
CORS_CREDENTIALS=false

# Rate limiting.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Auth anomaly detection logs.
SECURITY_AUTH_FAILURE_WINDOW_MS=60000
SECURITY_AUTH_FAILURE_THRESHOLD=10

# Optional JWT / OIDC access tokens (RFC 7519). When JWT_ISSUER is set together with
# JWT_SECRET (HS256 dev) or JWT_JWKS_URI (OIDC JWKS), routes enforce subject binding:
# create: employeeId === sub; approve/reject: managerId === sub; cancel: cancelledBy === sub
# and actor is employee or manager on the request; balance GET: employeeId param === sub;
# list: employeeId or managerId query must match sub.
JWT_ISSUER=
JWT_AUDIENCE=
JWT_JWKS_URI=
JWT_SECRET=
# Claim name for the end-user identifier (default sub).
JWT_SUB_CLAIM=
# Claim that carries roles array/string (default roles).
JWT_ROLES_CLAIM=
